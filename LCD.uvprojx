#include "sys.h"
#include "delay.h"
#include "servo.h"
#include "usart.h"
#include <stdio.h>

/* 系统时钟初始化（72MHz） */
static void SystemClock_Init(void)
{
    ErrorStatus HSEStartUpStatus;
    RCC_DeInit();
    RCC_HSEConfig(RCC_HSE_ON);
    HSEStartUpStatus = RCC_WaitForHSEStartUp();
    if(HSEStartUpStatus == SUCCESS)
    {
        RCC_HCLKConfig(RCC_SYSCLK_Div1);
        RCC_PCLK2Config(RCC_HCLK_Div1);
        RCC_PCLK1Config(RCC_HCLK_Div2);
        RCC_PLLConfig(RCC_PLLSource_HSE_Div1, RCC_PLLMul_9);
        RCC_PLLCmd(ENABLE);
        while(RCC_GetFlagStatus(RCC_FLAG_PLLRDY) == RESET);
        RCC_SYSCLKConfig(RCC_SYSCLKSource_PLLCLK);
        while(RCC_GetSYSCLKSource() != 0x08);
    }
}

/* 安全打印角度（整数 + 1 位小数） */
static void PrintAngle(uint8_t ch, float angle)
{
    int a_int = (int)angle;
    int a_dec = (int)((angle - a_int) * 10 + 0.5);
    printf("CH%d: %d.%d deg\r\n", ch, a_int, a_dec);
}

/**
 * @brief 机械臂抓取流程（阻塞执行，步长 1°，延时 20ms/步）
 */
static void GrabSequence(void)
{
    // 步骤1：3 号舵机 60° -> 150°
    Servo_SetAngle_Soft(3, 150.0f, 1.0f, 20);
    // 步骤2：2 号舵机 15° -> 45°
    Servo_SetAngle_Soft(2, 45.0f, 1.0f, 20);
    // 步骤3：1 号舵机 0° -> 90°（修改后：0→90）
    Servo_SetAngle_Soft(1, 90.0f, 1.0f, 20);
    // 步骤4：3 号舵机 150° -> 60°
    Servo_SetAngle_Soft(3, 60.0f, 1.0f, 20);
    // 步骤5：2 号舵机 45° -> 15°
    Servo_SetAngle_Soft(2, 15.0f, 1.0f, 20);
    // 1 号舵机保持 90°，不再回正
}

int main(void)
{
    uint8_t i;

    SystemClock_Init();
    delay_init();
    NVIC_PriorityGroupConfig(NVIC_PriorityGroup_2);
    uart_init(115200);
    Servo_Init();

    // 初始角度设定：CH1=0°, CH2=15°, CH3=60°, CH4=0°
    Servo_SetAngle(1, 0.0f);   // 修改
    Servo_SetAngle(2, 15.0f);
    Servo_SetAngle(3, 60.0f);
    Servo_SetAngle(4, 0.0f);

    printf("\r\n--- Robot Arm Starting ---\r\n");

    // 执行抓取序列
    GrabSequence();

    // 打印最终角度
    printf("--- Grab Complete, Current Angles ---\r\n");
    for(i = 1; i <= 4; i++)
        PrintAngle(i, Servo_GetAngle(i));
    printf("------------------------------------\r\n");

    while(1)
    {
    }
}
